# ==============================================================================
# ReconCTRL Environment Variables Template
# ==============================================================================

# --- PostgreSQL Database ---
POSTGRES_USER=recon
POSTGRES_PASSWORD=securepasswordhere
POSTGRES_DB=reconctrl
# DB Host inside Docker Compose is 'postgres'.
DATABASE_URL=postgresql+asyncpg://recon:securepasswordhere@postgres:5432/reconctrl

# --- Redis Cache & Broker ---
# Redis Host inside Docker Compose is 'redis'.
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Secret key for JWT generation/verification. Generate a strong key in production.
SECRET_KEY=change_this_to_a_secure_random_string_in_production
JWT_SECRET_KEY=change_this_to_a_secure_random_string_in_production
JWT_ALGORITHM=HS256

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Claude API (optional, for ai_summary module) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-20241022

# --- Frontend (Vite) ---
# Endpoint where Vite React application communicates with FastAPI API
VITE_API_URL=http://localhost:8000
