# ==============================================================================
# ReconCTRL Gitignore Configurations
# ==============================================================================

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and editors
.idea/
.project
.classpath
.cproject
.settings/
.vscode/
*.sublime-workspace
*.sublime-project
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment & Private configurations
.env
.env.local
.env.*.local
*.pem
*.key

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Frontend (Node / Vite) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/pnpm-lock.yaml*
frontend/.svelte-kit/
frontend/.next/

# --- Backend & Worker (Python / Poetry) ---
backend/__pycache__/
backend/**/*.py[cod]
backend/*$py.class
backend/.venv/
backend/venv/
backend/env/
backend/ENV/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.poetry/
backend/dist/
backend/build/
backend/*.egg-info/

worker/__pycache__/
worker/**/*.py[cod]
worker/*$py.class
worker/.venv/
worker/venv/
worker/env/

# --- Databases & Infrastructure ---
pgdata/
.redis/
docker/volumes/
